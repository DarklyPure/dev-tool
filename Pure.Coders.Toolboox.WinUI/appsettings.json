{
  "ApplicationName": "Pure Coders Toolkit",
  "ApplicationVersion": "1.0.0",
  "ApplicationDescription": "A Code Generator, for multiple languages.",
  "ApplicationRootDirectory": "",
  "LogsDirectory": "Logs",
  "ExportsDirectory": "Exports",
  "ImportsDirectory": "Imports",
  "FileExtensions": [
    ".dll",
    ".cs"
  ],
  "CodeObjectMappings": [
    {
      "CodeFlavour": "C#",
      "InputType": "Type",
      "CodeObject": "Builder"
    }
  ],
  "CodeFlavours": [
    "C#",
    "Typescript"
  ],
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}